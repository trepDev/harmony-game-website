---
import { changeLanguage, t } from "i18next";
import Layout from "~/layouts/MarkdownLayout.astro";

changeLanguage("fr");

const metadata = {
  title: t("about.title"),
  description: t("html_header.about_description")
};
const pages = await Astro.glob("./about_content.md");
let Content;
for (const page of pages) {
    Content = page.Content;
}
---

<Layout metadata={metadata}>
  <Content />
</Layout>
